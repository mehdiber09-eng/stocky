# Copy this file to .env.backend and fill in your values

# ===== Sécurité =====
# Génère une clé forte avec : python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-strong-random-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
APP_ENV=development

# ===== CORS =====
# Liste séparée par virgules ou * pour tout autoriser (dev uniquement)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== Limites freemium =====
FREE_TRIALS_LIMIT=5
ALERT_THRESHOLD=0.5

# ===== Alertes email (optionnel) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ===== Conseiller IA (Groq, optionnel) =====
GROQ_API_KEY=
