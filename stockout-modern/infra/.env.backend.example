# Copy this file to .env.backend and fill in your values

# ===== Sécurité =====
# Génère une clé forte avec : python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-strong-random-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
APP_ENV=development

# ===== CORS =====
# Liste séparée par virgules ou * pour tout autoriser (dev uniquement)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== URLs publiques =====
# FRONTEND_URL: domaine public du frontend, utilisé après le callback Google
# API_BASE_URL: domaine public du backend, utilisé comme redirect_uri OAuth
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

# ===== Limites freemium =====
FREE_TRIALS_LIMIT=5
ALERT_THRESHOLD=0.5

# ===== Alertes email (optionnel) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ===== Conseiller IA (Groq, optionnel) =====
GROQ_API_KEY=

# ===== Stripe (card payments) =====
# Set STRIPE_SECRET_KEY (sk_...) and STRIPE_PUBLISHABLE_KEY (pk_...)
# After creating a webhook in the Stripe dashboard, paste the signing secret here:
# STRIPE_WEBHOOK_SECRET=whsec_...
# Example (do NOT commit secrets into VCS):
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# ===== OAuth Google =====
# Google Cloud Console > APIs & Services > Credentials > OAuth client ID
# Authorized redirect URI:
#   local: http://localhost:8000/auth/oauth/google/callback
#   prod:  https://api.your-domain.com/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
